{
  "name": "ci-cd-flow",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@sap/eslint-plugin-cds": "^4.2.4",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4"
  },
  "scripts": {
    "start": "cds-serve",
    "lint": "eslint .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,cds}": "eslint --fix --no-warn-ignored",
    "*.{json,md,yaml,yml}": "prettier --write"
  },
  "private": true,
  "cds": {
    "requires": {
      "db-ext": {
        "[development]": {
          "model": "db/sqlite"
        },
        "[production]": {
          "model": "db/hana"
        }
      }
    }
  }
}
